<div class="space-y-6">
    <div>
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Mi Panel Personal</h1>
        <p class="text-gray-500">Bienvenido, aquí puedes ver tus evaluaciones y resultados</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <div class="flex flex-row items-center justify-between pb-2">
                <h3 class="text-sm font-medium text-gray-500">Tests Pendientes</h3>
                <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
                <div class="text-3xl font-bold text-gray-900">2</div>
                <p class="text-xs text-amber-600 mt-1 font-medium">Próximo vence en 3 días</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <div class="flex flex-row items-center justify-between pb-2">
                <h3 class="text-sm font-medium text-gray-500">En Progreso</h3>
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
            </div>
            <div>
                <div class="text-3xl font-bold text-gray-900">1</div>
                <p class="text-xs text-gray-500 mt-1">60% completado</p>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
            <div class="flex flex-row items-center justify-between pb-2">
                <h3 class="text-sm font-medium text-gray-500">Completados</h3>
                <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div>
                <div class="text-3xl font-bold text-gray-900">8</div>
                <p class="text-xs text-emerald-600 mt-1 font-medium">2 este mes</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 border-l-4 border-l-blue-500 p-6">
        <div class="flex flex-row items-start gap-4">
            <svg class="w-6 h-6 text-blue-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <div class="flex-1">
                <h3 class="text-lg font-bold text-gray-900 mb-1">Recordatorio Importante</h3>
                <p class="text-sm text-gray-600">
                    Tienes 2 evaluaciones pendientes. Recuerda que estas evaluaciones nos ayudan a brindarte mejor apoyo.
                    Los resultados son confidenciales y solo tu orientador tiene acceso a ellos.
                </p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200">
            <h3 class="text-lg font-bold text-gray-900">Tests Asignados</h3>
        </div>
        <div class="p-6 space-y-4">
            
            <div class="p-4 border border-gray-200 rounded-lg hover:shadow-md transition-shadow bg-white">
                <div class="flex items-start justify-between mb-3">
                    <div class="flex-1">
                        <h4 class="text-base font-semibold text-gray-900 mb-1">Evaluación de Ansiedad</h4>
                        <div class="flex items-center gap-4 text-xs text-gray-500">
                            <span class="flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                Vence: 10 de febrero
                            </span>
                            <span class="text-amber-600 font-medium">Pendiente</span>
                        </div>
                    </div>
                    <button class="bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium py-2 px-4 rounded-md transition-colors">
                        Comenzar
                    </button>
                </div>
            </div>

            <div class="p-4 border border-gray-200 rounded-lg hover:shadow-md transition-shadow bg-white">
                <div class="flex items-start justify-between mb-3">
                    <div class="flex-1">
                        <h4 class="text-base font-semibold text-gray-900 mb-1">Test de Inteligencia Emocional</h4>
                        <div class="flex items-center gap-4 text-xs text-gray-500">
                            <span class="flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                Vence: 08 de febrero
                            </span>
                            <span class="text-blue-600 font-medium">En progreso</span>
                        </div>
                    </div>
                    <button class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-4 rounded-md transition-colors">
                        Continuar
                    </button>
                </div>
                <div class="space-y-1">
                    <div class="w-full bg-gray-200 rounded-full h-2">
                        <div class="bg-blue-600 h-2 rounded-full" style="width: 60%"></div>
                    </div>
                    <p class="text-xs text-gray-500 text-right">60% completado</p>
                </div>
            </div>

             <div class="p-4 border border-gray-200 rounded-lg hover:shadow-md transition-shadow bg-white">
                <div class="flex items-start justify-between mb-3">
                    <div class="flex-1">
                        <h4 class="text-base font-semibold text-gray-900 mb-1">Evaluación de Autoestima</h4>
                        <div class="flex items-center gap-4 text-xs text-gray-500">
                            <span class="flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                Vence: 15 de febrero
                            </span>
                            <span class="text-amber-600 font-medium">Pendiente</span>
                        </div>
                    </div>
                    <button class="bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium py-2 px-4 rounded-md transition-colors">
                        Comenzar
                    </button>
                </div>
            </div>

        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="p-6 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-lg font-bold text-gray-900">Tests Completados Recientes</h3>
            <button class="text-sm text-gray-600 hover:text-gray-900 border border-gray-300 px-3 py-1 rounded-md transition-colors bg-white">Ver Todos</button>
        </div>
        <div class="p-6 space-y-3">
            <div class="flex items-center justify-between p-4 bg-emerald-50 rounded-lg border border-emerald-100">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-emerald-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <div>
                        <p class="text-sm font-medium text-gray-900">Evaluación de Depresión</p>
                        <p class="text-xs text-gray-500 mt-0.5">Completado el 28 de enero</p>
                    </div>
                </div>
                <div class="text-right flex items-center">
                    <span class="text-sm font-medium text-emerald-700 mr-3">Nivel Normal</span>
                    <button class="text-sm text-gray-600 hover:text-gray-900 hover:underline">Ver Resultados</button>
                </div>
            </div>

            <div class="flex items-center justify-between p-4 bg-emerald-50 rounded-lg border border-emerald-100">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-emerald-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <div>
                        <p class="text-sm font-medium text-gray-900">Test de Inteligencia Emocional</p>
                        <p class="text-xs text-gray-500 mt-0.5">Completado el 15 de enero</p>
                    </div>
                </div>
                <div class="text-right flex items-center">
                    <span class="text-sm font-medium text-emerald-700 mr-3">Nivel Alto</span>
                    <button class="text-sm text-gray-600 hover:text-gray-900 hover:underline">Ver Resultados</button>
                </div>
            </div>
        </div>
    </div>
</div>